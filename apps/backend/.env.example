# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cospec_db"

# App
PORT=3001
NODE_ENV=development

# JWT (will be used in auth-y-roles change)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Web URL for CORS
WEB_URL=http://localhost:3000

# CORS origins (comma-separated, supports multiple)
CORS_ORIGINS=http://localhost:3000,exp://localhost:8081
